const __vite__css = "/* ==========================================================================\r\n   Memo App — Dark Compact Design\r\n   ========================================================================== */\r\n\r\n/* ---------- 1. デザイントークン ---------- */\r\n:root {\r\n  --bg-primary: #111;\r\n  --bg-surface: #1a1a1a;\r\n  --bg-input: #0d0d0d;\r\n  --bg-hover: #222;\r\n\r\n  --text-primary: #ddd;\r\n  --text-secondary: #888;\r\n  --text-muted: #555;\r\n\r\n  --border: #333;\r\n  --border-focus: #666;\r\n\r\n  --accent: #6c8cff;\r\n  --accent-hover: #5a7aee;\r\n  --accent-soft: rgba(108, 140, 255, 0.12);\r\n\r\n  --danger: #e85555;\r\n  --danger-hover: #d44;\r\n\r\n  --tag-color: #b89cff;\r\n  --tag-bg: rgba(184, 156, 255, 0.12);\r\n\r\n  --font-sans: 'Inter', 'Noto Sans JP', system-ui, -apple-system, sans-serif;\r\n  --font-mono: 'SF Mono', 'Fira Code', ui-monospace, monospace;\r\n\r\n  --radius: 4px;\r\n  --transition: 0.15s ease;\r\n}\r\n\r\n/* ---------- 2. リセット ---------- */\r\n*,\r\n*::before,\r\n*::after {\r\n  box-sizing: border-box;\r\n  margin: 0;\r\n  padding: 0;\r\n}\r\n\r\nhtml {\r\n  font-size: 14px;\r\n  -webkit-font-smoothing: antialiased;\r\n}\r\n\r\nbody {\r\n  font-family: var(--font-sans);\r\n  background: var(--bg-primary);\r\n  color: var(--text-primary);\r\n  line-height: 1.5;\r\n  min-height: 100vh;\r\n}\r\n\r\n::selection {\r\n  background: var(--accent-soft);\r\n  color: var(--accent);\r\n}\r\n\r\n/* ---------- 3. アプリコンテナ ---------- */\r\n#app {\r\n  max-width: 1100px;\r\n  margin: 0 auto;\r\n  padding: 16px 12px;\r\n  min-height: 100vh;\r\n}\r\n\r\n\r\n/* ---------- 4. メモ行 ---------- */\r\n.memo-container {\r\n  display: flex;\r\n  flex-direction: column;\r\n}\r\n\r\n.memo-row {\n  display: flex;\n  align-items: stretch;\n  border-bottom: 1px solid var(--border);\n  min-height: 36px;\n  transition: background var(--transition), box-shadow var(--transition);\n}\n\n.memo-row:hover {\n  background: var(--bg-hover);\n}\n\n.memo-row:focus-within {\n  background: var(--bg-input);\n  box-shadow: inset 0 0 0 1px var(--border-focus);\n}\n\r\n/* タイトルセル */\r\n.title-cell {\r\n  flex: 0 0 auto;\r\n  border-right: 1px solid var(--border);\r\n  display: flex;\r\n}\r\n\r\n.title-input {\n  width: 180px;\n  min-width: 80px;\n  max-width: 500px;\n  resize: none;\n  overflow: hidden;\n  background: transparent;\r\n  border: none;\r\n  color: var(--text-primary);\r\n  font-family: var(--font-sans);\r\n  font-size: 0.875rem;\r\n  font-weight: 600;\r\n  padding: 8px 10px;\r\n  white-space: nowrap;\r\n  line-height: 1.4;\r\n}\r\n\r\n.title-input:focus {\n  outline: none;\n  background: transparent;\n}\n\r\n/* コンテンツセル */\r\n.content-cell {\r\n  flex: 1;\r\n  display: flex;\r\n  flex-direction: column;\r\n  min-width: 0;\r\n}\r\n\r\n.content-input {\n  width: 100%;\n  min-height: 32px;\n  resize: none;\n  overflow: hidden;\n  background: transparent;\n  border: none;\r\n  color: var(--text-secondary);\r\n  font-family: var(--font-sans);\r\n  font-size: 0.85rem;\r\n  padding: 8px 10px;\r\n  line-height: 1.5;\r\n}\r\n\r\n.content-input:focus {\n  outline: none;\n  background: transparent;\n  color: var(--text-primary);\n}\n\r\n/* アクションセル */\r\n.actions-cell {\n  flex: 0 0 auto;\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n  align-items: stretch;\n  gap: 6px;\n  padding: 8px 6px;\n  border-left: 1px solid var(--border);\n}\n\r\n\r\n/* ---------- 5. タグ行 ---------- */\r\n.tag-row {\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  align-items: center;\r\n  gap: 4px;\r\n  padding: 0 10px 8px 10px;\r\n  position: relative;\r\n  min-height: 22px;\r\n}\r\n\r\n.tag-badge {\r\n  display: inline-flex;\r\n  align-items: center;\r\n  font-size: 0.7rem;\r\n  font-weight: 500;\r\n  color: var(--tag-color);\r\n  background: var(--tag-bg);\r\n  padding: 1px 8px;\r\n  border-radius: 10px;\r\n  letter-spacing: 0.2px;\r\n}\r\n\r\n.tag-add-btn {\r\n  font-size: 0.68rem;\r\n  cursor: pointer;\r\n  border: 1px d