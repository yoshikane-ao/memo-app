# Docker Compose で使うPostgreSQL認証情報
# 使い方:
#   cp .env.example .env
#   .env の値を好きなものに書き換えてから `docker compose up --build`
#
# 注意:
# - `.env` は .gitignore 済み。絶対にコミットしないこと
# - 本番(EC2)では GitHub Actions が GitHub Secrets から .env を自動生成する
POSTGRES_USER=memo_db
POSTGRES_PASSWORD=change_me_local_only
POSTGRES_DB=memo_db
