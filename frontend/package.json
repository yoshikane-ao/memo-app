{
  "name": "memo-frontend",
  "private": true,
  "version": "0.0.0",
  "description": "Memo app frontend",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "e2e:serve": "npm run build && node e2e/webServer.mjs",
    "preview": "vite preview",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "concurrently": "^8.0.0",
    "jsdom": "^29.0.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.5"
  }
}
