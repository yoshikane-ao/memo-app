# Optional. Leave empty to use relative API paths.
# VITE_API_BASE_URL=

# Optional. Vite dev server proxy target.
# If omitted, frontend/vite.config.ts will read ../backend/.env PORT
# and fall back to http://127.0.0.1:3004.
# API_PROXY_TARGET=http://127.0.0.1:3004

# Sentry (optional). 空なら初期化スキップ。
# VITE_SENTRY_DSN=
# VITE_SENTRY_TRACES_SAMPLE_RATE=0
