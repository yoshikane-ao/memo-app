HOST=0.0.0.0
PORT=3004
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
# pino のログレベル: fatal / error / warn / info / debug / trace / silent
LOG_LEVEL=info
# Sentry (optional). 空なら初期化スキップ。
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0
# 認証（JWT / Cookie）
# JWT_SECRET は本番環境で必須（32 文字以上のランダム文字列）。
# ローカル開発では未設定でも dev fallback が効く。
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
# COOKIE_SECURE は NODE_ENV=production で既定 true、それ以外 false。
# COOKIE_SECURE=true
# COOKIE_DOMAIN=example.com
DATABASE_URL="postgresql://postgres:password@localhost:5432/memo?schema=public"
