// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Memos {
  id          Int             @id @default(autoincrement())
  orderIndex  Int             @default(0)
  width       Int?
  height      Int?
  title       String          @db.VarChar(20)
  content     String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  histories   MemoHistories[]
  memo_tags   memo_tags[]
  memoLayouts MemoLayouts?
}

model MemoHistories {
  id        Int      @id @default(autoincrement())
  memoId    Int      @map("memo_id")
  title     String
  content   String?
  createdAt DateTime @default(now()) @map("created_at")
  memo      Memos    @relation(fields: [memoId], references: [id], onDelete: Cascade)
}

model Tags {
  id        Int         @id @default(autoincrement())
  title     String      @unique @db.VarChar(20)
  memo_tags memo_tags[]
}

// メモとタグの中間テーブル
model memo_tags {
  memo_id Int @map("memo_id")
  tag_id  Int @map("tag_id")

  memo Memos @relation(fields: [memo_id], references: [id], onDelete: Cascade)
  tag  Tags  @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([memo_id, tag_id])
}

model MemoLayouts {
  id     Int @id @default(autoincrement())
  memoId Int @unique @map("memo_id")

  // --- レイアウト情報 ---
  width  Int @default(300)
  height Int @default(200)

  // --- 並び替え順 (追加) ---
  sortOrder Int      @default(0) @map("sort_order")
  updatedAt DateTime @updatedAt @map("updated_at")

  memo Memos @relation(fields: [memoId], references: [id], onDelete: Cascade)

  @@map("memo_layouts")
}
