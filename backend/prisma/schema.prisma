// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String?  @map("display_name")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  memos Memos[]
  tags  Tags[]

  @@map("users")
}

model Memos {
  id         Int             @id @default(autoincrement())
  userId     Int             @map("user_id")
  orderIndex Int             @default(0)
  width      Int?
  height     Int?
  title      String
  content    String
  deletedAt  DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  histories  MemoHistories[]
  memo_tags  memo_tags[]

  @@index([userId])
}

model MemoHistories {
  id        Int      @id @default(autoincrement())
  memoId    Int      @map("memo_id")
  title     String
  content   String?
  createdAt DateTime @default(now()) @map("created_at")
  memo      Memos    @relation(fields: [memoId], references: [id], onDelete: Cascade)
}

model Tags {
  id        Int         @id @default(autoincrement())
  userId    Int         @map("user_id")
  title     String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  memo_tags memo_tags[]

  @@unique([userId, title])
  @@index([userId])
}

// Memo/tag join table
model memo_tags {
  memo_id Int @map("memo_id")
  tag_id  Int @map("tag_id")

  memo Memos @relation(fields: [memo_id], references: [id], onDelete: Cascade)
  tag  Tags  @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([memo_id, tag_id])
}

model Quizs {
  id                Int                 @id @default(autoincrement())
  word              String
  mean              String
  questionText      String?
  hint              String?
  groupName         String?
  isFavorite        Boolean             @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  quizTagsRelations quizTagsRelations[]
  quizSets          quizSet[]
  choices           quizChoice[]
}

model quizChoice {
  id        Int    @id @default(autoincrement())
  quiz_id   Int    @map("quiz_id")
  choiceText String
  Quizs     Quizs  @relation(fields: [quiz_id], references: [id], onDelete: Cascade)
}

model quizTag {
  id                Int                 @id @default(autoincrement())
  tagName           String              @unique
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  quizTagsRelations quizTagsRelations[]
}

model quizTagsRelations {
  quiz_id    Int @map("quiz_id")
  quizTag_id Int @map("quizTag_id")

  Quizs   Quizs   @relation(fields: [quiz_id], references: [id], onDelete: Cascade)
  quizTag quizTag @relation(fields: [quizTag_id], references: [id], onDelete: Cascade)

  @@id([quiz_id, quizTag_id])
}

model quizSet {
  id      Int @id @default(autoincrement())
  quiz_id Int @map("quiz_id")

  Quizs Quizs @relation(fields: [quiz_id], references: [id], onDelete: Cascade)
}
