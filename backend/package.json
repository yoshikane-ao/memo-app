{
  "name": "memo-backend",
  "version": "1.0.0",
  "description": "Memo app backend API",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:api": "jest --config jest.config.cjs --runInBand",
    "check:architecture": "node ../tooling/check-architecture.mjs backend",
    "test:watch": "jest --watch",
    "dev": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "build": "node ./node_modules/typescript/bin/tsc",
    "start": "node dist/src/server.js",
    "e2e:serve": "npm run build && node dist/src/test/e2eApiServer.js"
  },
